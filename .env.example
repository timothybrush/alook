# =============================================================================
# Alook — Environment Variables
# =============================================================================
# Copy this file to .env and customize for your local development setup.
# All variables are optional — sensible defaults are built in.
#
# The dev:cli script auto-sets ALOOK_SERVER_URL and ALOOK_PROJECT_ROOT,
# so you typically only need .env overrides for non-default agent paths or
# tuning daemon behavior.
#
# For auth secrets (Better Auth, OAuth), see src/web/.dev.vars.example.
# =============================================================================


# =============================================================================
# Server & Project
# =============================================================================

# API server URL. Set automatically by `pnpm dev:cli`.
# Production default: https://alook.ai
# ALOOK_SERVER_URL=http://localhost:3000

# Project root directory. Set automatically by `pnpm dev:cli`.
# Used to locate .alook/ config dir in dev mode.
# ALOOK_PROJECT_ROOT=/path/to/alook

# Email domain suffix for agent handles (e.g. agent@alook.ai)
# ALOOK_DOMAIN=alook.ai


# =============================================================================
# Local Dev Service URLs & Ports
# =============================================================================
# Used for service-binding fallbacks during local development.

# WebSocket Durable Object worker URL (must match src/ws-do/wrangler.toml port)
# DEV_WS_DO_URL=http://localhost:8789

# Email worker URL (must match src/email-worker/wrangler.toml port)
# DEV_EMAIL_WORKER_URL=http://localhost:8788

# Daemon health check server port
# ALOOK_HEALTH_PORT=19514


# =============================================================================
# Daemon — Identity
# =============================================================================

# Unique daemon identifier (defaults to hostname, suffixed with profile if set)
# ALOOK_DAEMON_ID=my-machine

# Human-readable device name shown in the web UI
# ALOOK_DAEMON_DEVICE_NAME=My MacBook

# Display name for the agent runtime
# ALOOK_AGENT_RUNTIME_NAME=Local Agent


# =============================================================================
# Daemon — Storage
# =============================================================================

# Directory where the daemon stores workspace checkouts
# Dev default: <project-root>/.alook/workspaces/
# Prod default: ~/.alook/workspaces
# ALOOK_WORKSPACES_ROOT=~/.alook/workspaces


# =============================================================================
# Daemon — Timing
# =============================================================================

# How often the daemon polls for new tasks (duration string: e.g. 3s, 500ms)
# ALOOK_DAEMON_POLL_INTERVAL=3s

# Maximum time a single agent task can run before being killed
# ALOOK_AGENT_TIMEOUT=2h

# Maximum number of tasks the daemon runs concurrently
# ALOOK_DAEMON_MAX_CONCURRENT_TASKS=20

# Keep shell environment variables across tasks
# ALOOK_KEEP_ENV_AFTER_TASK=false

# Graceful shutdown timeout before force-exit (ms)
# ALOOK_SHUTDOWN_TIMEOUT_MS=5000

# Message batch size — how many messages to buffer before flushing to server
# ALOOK_MESSAGE_BATCH_SIZE=20

# Message flush interval — max time before a partial batch is sent (ms)
# ALOOK_MESSAGE_FLUSH_INTERVAL_MS=2000

# Time (seconds) before a dispatched task is considered stale and failed
# ALOOK_STALE_DISPATCH_TIMEOUT_S=20


# =============================================================================
# Shared Timing Constants
# =============================================================================
# Used by both web and CLI for real-time status tracking.

# Client-side poll interval (ms)
# POLL_INTERVAL_MS=3000

# Time (ms) without liveness update before a runtime is considered offline
# OFFLINE_THRESHOLD_MS=9000

# How often the web UI polls for new events (ms)
# EVENT_POLL_INTERVAL_MS=2000


# =============================================================================
# Web Client (browser-side, requires NEXT_PUBLIC_ prefix)
# =============================================================================

# App URL used by auth client (defaults to http://localhost:3000)
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# WebSocket Durable Object port (dev only, must match src/ws-do/wrangler.toml)
# NEXT_PUBLIC_WS_DO_PORT=8789

# Initial reconnect delay (ms), doubles on each retry
# NEXT_PUBLIC_WS_RECONNECT_DELAY_MS=1000

# Maximum reconnect delay cap (ms)
# NEXT_PUBLIC_WS_RECONNECT_MAX_DELAY_MS=30000


# =============================================================================
# Agent Paths
# =============================================================================
# Paths to CLI agent binaries. Override if not on $PATH.

# ALOOK_CLAUDE_PATH=claude
# ALOOK_CODEX_PATH=codex
# ALOOK_OPENCODE_PATH=opencode


# =============================================================================
# Agent Models
# =============================================================================
# Override the default model for each agent runtime.

# ALOOK_CLAUDE_MODEL=
# ALOOK_CODEX_MODEL=
# ALOOK_OPENCODE_MODEL=


# =============================================================================
# Logging
# =============================================================================

# Log level: error | warn | info | debug
# ALOOK_LOG_LEVEL=info
