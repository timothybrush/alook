    "nanoid": "^5.1.11",
    "next": "16.2.7",
    "next-themes": "^0.4.6",
    "postal-mime": "^2.7.4",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-resizable-panels": "^4.11.2",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-external-links": "^3.0.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.10.0",
    "shiki": "^4.2.0",
    "sonner": "^2.0.7",
