{
  "name": "@alook/daemon",
  "version": "0.0.157",
  "description": "Alook agent daemon — host-side runtime backend, process manager, credential proxy, and control plane.",
  "license": "Apache-2.0",
  "homepage": "https://github.com/alookai/alook#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alookai/alook.git",
    "directory": "src/daemon"
  },
  "bugs": {
    "url": "https://github.com/alookai/alook/issues"
  },
  "keywords": [
    "alook",
    "daemon",
    "ai",
    "agent",
    "email"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "alook-daemon": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --external commander --external ws && bun build src/cli/index.ts --outdir dist/cli --target node --format esm --external commander --external ws && node scripts/prepare-dist.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config ../../tests/integration/daemon/vitest.config.ts --passWithNoTests",
    "lint": "eslint .",
    "daemon": "tsx scripts/daemon.ts"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "ws": "^8.21.1"
  },
  "devDependencies": {
    "@alook/shared": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.5",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
