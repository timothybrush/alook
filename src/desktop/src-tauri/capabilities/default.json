{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for all platforms",
  "windows": ["main"],
  "remote": {
    "urls": ["https://alook.ai", "http://localhost:3000"]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
